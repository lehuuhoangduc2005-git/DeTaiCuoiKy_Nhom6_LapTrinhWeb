@{
    ViewData["Title"] = "Từ chối truy cập - ToDoTech";
}

<style>
    .access-denied-container {
        animation: fadeInUp 0.6s ease-in-out;
    }

    .error-card {
        border: none;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .error-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
        }

    .pulse-icon {
        animation: pulseDanger infinite 2s ease-in-out;
    }

    .btn-custom {
        border-radius: 12px;
        padding: 12px 28px;
        transition: all 0.2s ease;
    }

        .btn-custom:hover {
            transform: scale(1.03);
        }
    
    /* Hiệu ứng trồi lên khi load trang */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Hiệu ứng sóng lan tỏa xung quanh icon cảnh báo */
    @@keyframes pulseDanger {
        0% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4);
        }

        70% {
            box-shadow: 0 0 0 18px rgba(220, 53, 69, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }
</style>

<div class="container d-flex align-items-center justify-content-center access-denied-container mt-5 pt-4" style="max-width: 600px;">
    <div class="card error-card p-5 text-center bg-white w-100">
        
        <div class="text-danger mb-4 bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center pulse-icon mx-auto" style="width: 95px; height: 95px;">
            <i class="fa-solid fa-triangle-exclamation display-4"></i>
        </div>

        <h1 class="fw-extrabold text-dark tracking-tight mb-2" style="font-size: 2.6rem; font-family: 'Segoe UI', system-ui, sans-serif;">
            Access Denied
        </h1>
        
        <div class="d-inline-block mx-auto mb-4">
            <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2 rounded-pill fw-bold text-uppercase small tracking-wider">
                🔒 HTTP Error 403: Forbidden
            </span>
        </div>

        <p class="text-muted fs-5 lh-base px-2">
            Hệ thống bảo mật phát hiện tài khoản hiện tại của bạn không đủ đặc quyền <strong class="text-dark">(Quyền Admin)</strong> để truy cập vào tài nguyên này.
        </p>

        <hr class="my-4 opacity-25" />

        <div class="d-flex gap-3 justify-content-center flex-column flex-sm-row">
            <a asp-controller="CongViec" asp-action="Index" class="btn btn-primary btn-custom fw-bold shadow-sm d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-house me-2"></i> Về Trang chủ
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-custom fw-semibold d-flex align-items-center justify-content-center">
                <i class="fa-solid fa-arrow-left me-2"></i> Quay lại trang cũ
            </a>
        </div>
        
    </div>
</div>