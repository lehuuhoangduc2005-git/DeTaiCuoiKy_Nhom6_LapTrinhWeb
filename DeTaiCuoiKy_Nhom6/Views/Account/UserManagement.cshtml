@{
    ViewData["Title"] = "Quản lý Thành viên - ToDoTech";
}

<style>
    .stat-card {
        border-left: 5px solid;
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: scale(1.03);
        }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.04);
    }

    .search-box {
        border-radius: 30px;
        padding-left: 20px;
    }
</style>

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="CongViec" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thành viên</li>
                </ol>
            </nav>
            <h2 class="fw-bold text-dark mb-0">👥 Quản lý Thành viên Hệ thống</h2>
        </div>
        <button type="button" class="btn btn-success px-4 py-2 shadow-sm fw-bold d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <span class="fs-5 me-2">+</span> Thêm Thành Viên Mới
        </button>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card stat-card border-start border-primary shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Tổng tài khoản</h6>
                        <h3 class="fw-bold mb-0 text-dark">12</h3>
                    </div>
                    <div class="fs-1 text-primary opacity-50">👥</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-start border-danger shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Quản trị viên (Admin)</h6>
                        <h3 class="fw-bold mb-0 text-danger">2</h3>
                    </div>
                    <div class="fs-1 text-danger opacity-50">🛡️</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-start border-success shadow-sm h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold">Đang hoạt động</h6>
                        <h3 class="fw-bold mb-0 text-success">10</h3>
                    </div>
                    <div class="fs-1 text-success opacity-50">🟢</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                <p class="text-muted mb-0">Danh sách tài khoản được đăng ký chính thức thuộc nhóm dự án <b>Đề tài Cuối Kỳ - Nhóm 6</b>.</p>
                <div style="max-width: 350px;" class="w-100 position-relative">
                    <input type="text" id="userSearchInput" class="form-control search-box py-2 shadow-sm" placeholder="🔍 Nhập họ tên hoặc email cần tìm..." onkeyup="filterUserTable()">
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle border-0" id="userTable">
                    <thead class="table-light border-bottom">
                        <tr>
                            <th scope="col" style="width: 8%" class="py-3 ps-3">STT</th>
                            <th scope="col" class="py-3">Họ và Tên</th>
                            <th scope="col" class="py-3">Email / Tài khoản</th>
                            <th scope="col" class="py-3">Vai trò</th>
                            <th scope="col" class="py-3">Trạng thái</th>
                            <th scope="col" style="width: 20%" class="text-center py-3">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-3 fw-bold text-muted">1</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold" style="width: 35px; height: 35px;">LH</div>
                                    <div>
                                        <span class="fw-bold text-dark d-block">@User.Identity?.Name</span>
                                        <small class="badge bg-opacity-10 bg-primary text-primary">Bạn hiện tại</small>
                                    </div>
                                </div>
                            </td>
                            <td class="fw-semibold">leduc7393@@gmail.com</td>
                            <td><span class="badge bg-danger px-3 py-2 rounded-pill shadow-xs">Admin</span></td>
                            <td><span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Active</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning me-1 px-3" onclick="alert('Tính năng chỉnh sửa tài khoản cá nhân đang thực thi trong Profile!')">Sửa</button>
                                <button class="btn btn-sm btn-light text-muted" disabled>Xóa</button>
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-3 fw-bold text-muted">2</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold" style="width: 35px; height: 35px;">NV</div>
                                    <span class="fw-bold text-dark">Nguyễn Văn A</span>
                                </div>
                            </td>
                            <td>nguyenvana@@example.com</td>
                            <td><span class="badge bg-secondary px-3 py-2 rounded-pill">User</span></td>
                            <td><span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Active</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning me-1 px-3">Sửa</button>
                                <button class="btn btn-sm btn-outline-danger px-3" onclick="deleteUserRow(this)">Xóa</button>
                            </td>
                        </tr>
                        <tr>
                            <td class="ps-3 fw-bold text-muted">3</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center me-2 fw-bold" style="width: 35px; height: 35px;">TT</div>
                                    <span class="fw-bold text-dark">Trần Thị B</span>
                                </div>
                            </td>
                            <td>tranthib@@example.com</td>
                            <td><span class="badge bg-secondary px-3 py-2 rounded-pill">User</span></td>
                            <td><span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1">Locked</span></td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning me-1 px-3">Sửa</button>
                                <button class="btn btn-sm btn-outline-danger px-3" onclick="deleteUserRow(this)">Xóa</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title fw-bold" id="addUserModalLabel">➕ Thêm thành viên hệ thống mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-close="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="addMemberForm">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ và tên</label>
                        <input type="text" class="form-control" placeholder="Nhập họ tên đầy đủ..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa chỉ Email</label>
                        <input type="email" class="form-control" placeholder="name@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu ban đầu</label>
                        <input type="password" class="form-control" value="123456Ab@@" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vai trò gán quyền</label>
                        <select class="form-select">
                            <option value="User" selected>User thường (Chỉ quản lý Task cá nhân)</option>
                            <option value="Admin">Admin (Toàn quyền hệ thống)</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-success fw-bold" onclick="submitAddMemberForm()">Xác nhận cấp tài khoản</button>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Live Search lọc dữ liệu trong bảng ngay lập tức
    function filterUserTable() {
        var input = document.getElementById("userSearchInput");
        var filter = input.value.toUpperCase();
        var table = document.getElementById("userTable");
        var tr = table.getElementsByTagName("tr");

        for (var i = 1; i < tr.length; i++) {
            var tdName = tr[i].getElementsByTagName("td")[1];
            var tdEmail = tr[i].getElementsByTagName("td")[2];
            if (tdName || tdEmail) {
                var txtValueName = tdName.textContent || tdName.innerText;
                var txtValueEmail = tdEmail.textContent || tdEmail.innerText;
                if (txtValueName.toUpperCase().indexOf(filter) > -1 || txtValueEmail.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    // 2. Giả lập xóa dòng thành viên
    function deleteUserRow(button) {
        if (confirm("Bạn có chắc chắn muốn xóa thành viên này khỏi cơ sở dữ liệu ToDoTech không?")) {
            var row = button.parentNode.parentNode;
            row.parentNode.removeChild(row);
        }
    }

    // 3. Giả lập thêm thành viên từ modal
    function submitAddMemberForm() {
        alert("Đã gửi yêu cầu tạo tài khoản thành công! Biểu mẫu sẽ kết nối trực tiếp đến API Register trong AccountController.");
        var modalEl = document.getElementById('addUserModal');
        var modal = bootstrap.Modal.getInstance(modalEl);
        modal.hide();
    }
</script>